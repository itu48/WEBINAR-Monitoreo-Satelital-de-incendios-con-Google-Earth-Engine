/**
 * Comparativa de épocas con conteo de imágenes
 */

if (typeof geometry !== 'undefined') {

  // --- CONFIGURACIÓN DE FECHAS ---
  var fecha_antes_inicio = '2019-04-01';
  var fecha_antes_fin    = '2019-06-01';
  
  var fecha_despues_inicio = '2019-08-01';
  var fecha_despues_fin    = '2019-09-01';

  // --- FUNCIÓN PARA PROCESAR Y CONTAR ---
  var procesarPeriodo = function(inicio, fin, nombre) {
    var coleccion = ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')
      .filterBounds(geometry)
      .filterDate(inicio, fin)
      .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 10));
    
    // Contamos cuántas imágenes hay en la colección
    var conteo = coleccion.size();
    print('Imágenes usadas para ' + nombre + ':', conteo);
    
    // Retornamos la imagen final recortada
    return coleccion.median().clip(geometry);
  };

  // Ejecutamos la función para ambos periodos
  var antes = procesarPeriodo(fecha_antes_inicio, fecha_antes_fin, 'Antes del Fuego');
  var despues = procesarPeriodo(fecha_despues_inicio, fecha_despues_fin, 'Después del Fuego');

  // --- VISUALIZACIÓN ---
  // ['B8', 'B4', 'B3'] INFRARROJO - VEG.SANA ROJO INTENSO
  // ['B11', 'B8', 'B2'] ESTRES HIDRICO
  // ['B12', 'B8A', 'B4'] FUEGO NARANJA- BRILLO
  var visParams = {
    bands: ['B4', 'B3', 'B2'],
    min: 0,
    max: 4000
  };

  Map.centerObject(geometry, 7);
  Map.addLayer(antes, visParams, '1. Antes del Fuego');
  Map.addLayer(despues, visParams, '2. Después del Fuego');

} else {
  print('⚠️ ERROR: Dibuja un polígono antes de dar a RUN.');
}
