/**
 * Comparativa de épocas: Antes y Después (Sentinel-2)
 */

if (typeof geometry !== 'undefined') {

  // --- CONFIGURACIÓN DE FECHAS ---
  var fecha_antes_inicio = '2019-05-01';
  var fecha_antes_fin    = '2019-07-01';
  
  var fecha_despues_inicio = '2019-08-01';
  var fecha_despues_fin    = '2019-09-01';

  // --- FUNCIÓN PARA PROCESAR IMÁGENES ---
  var obtenerImagen = function(inicio, fin) {
    return ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')
      .filterBounds(geometry)
      .filterDate(inicio, fin)
      .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 10))
      .median()
      .clip(geometry);
  };

  var antes = obtenerImagen(fecha_antes_inicio, fecha_antes_fin);
  var despues = obtenerImagen(fecha_despues_inicio, fecha_despues_fin);

  // --- PARÁMETROS PARA RESALTAR QUEMADOS (Falso Color Urbano/Incendio) ---
  // B12 (SWIR 2), B8 (NIR), B4 (Red)
  var visIncendio = {
    bands: ['B12', 'B8', 'B4'],
    min: 0,
    max: 4000
  };

  // --- MOSTRAR EN EL MAPA ---
  Map.centerObject(geometry, 10);
  
  // Añadimos las dos capas (puedes activarlas/desactivarlas a la derecha)
  Map.addLayer(antes, visIncendio, '1. Antes del Fuego');
  Map.addLayer(despues, visIncendio, '2. Después del Fuego');

  print('Comparación lista. Usa el panel "Layers" para alternar entre imágenes.');

} else {
  print('⚠️ ERROR: Dibuja un polígono antes de dar a RUN.');
}
